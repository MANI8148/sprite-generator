{
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && npm install -g opencode-ai",
  "postStartCommand": "nohup bash scripts/auto-improve.sh &",
  "forwardPorts": [4096],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
